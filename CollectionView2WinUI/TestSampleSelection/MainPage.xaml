<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TestSample.MainPage">


    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="20">
            <!-- Button to toggle selection mode -->
            <Button
                x:Name="ToggleSelectionModeBtn"
                Text="Switch to Multiple Selection"
                Clicked="OnToggleSelectionModeClicked"
                HorizontalOptions="Fill"/>

            <!-- CollectionView with single selection mode -->
            <CollectionView
                x:Name="MyCollectionView"
                SelectionMode="Single"
                ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="5"
                                Padding="10">
                            <Label Text="{Binding}"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
